{
  "name": "agent-hub",
  "private": true,
  "version": "2.0.4",
  "description": "SDD Orchestrator — Desktop app for Spec-Driven Development with Claude Code CLI",
  "author": {
    "name": "Agent Hub",
    "email": "dev@agenthub.app"
  },
  "homepage": "https://github.com/agent-hub/agent-hub",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "npm run build:electron && concurrently -n vite,electron -c blue,green \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "electron:build": "npm run build:electron && vite build && electron-builder",
    "postinstall": "electron-rebuild -f -w better-sqlite3 && node scripts/patch-electron-name.js"
  },
  "build": {
    "appId": "com.agenthub.app",
    "productName": "Agent Hub",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "public/icon.png",
      "plugin-registry/**/*",
      "plugins/registry/**/*",
      ".env"
    ],
    "asarUnpack": [
      "plugin-registry/**/*"
    ],
    "icon": "public/icon.png",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    },
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "ocasti",
        "repo": "agent-hub-dev"
      }
    ]
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "i18next": "^25.8.13",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.4",
    "semver": "^7.7.4",
    "tar": "^7.5.10",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/vite": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/semver": "^7.7.1",
    "@types/tar": "^6.1.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wait-on": "^9.0.4"
  }
}
